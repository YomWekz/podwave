# PodWave Admin System Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
ADMIN_PORT=4001
ADMIN_CLIENT_URL=http://localhost:3001

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=podwave_admin

# JWT Secret (generate a secure random string)
JWT_SECRET=replace_with_secure_secret

# Editor System API (for cross-system communication)
EDITOR_API_URL=http://localhost:4002
ADMIN_TO_EDITOR_SERVICE_TOKEN=replace_with_service_token
