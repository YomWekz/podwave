# PodWave Admin System Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
ADMIN_PORT=4001
ADMIN_CLIENT_URL=http://localhost:3001

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password_here
MYSQL_DATABASE=podwave_admin

# JWT Secret (legacy — kept for compatibility)
JWT_SECRET=replace_with_secure_secret

# ── Admin Authentication ───────────────────────────────────────────────────────
# Secret used to sign Admin JWT tokens (keep private, never commit real value)
ADMIN_JWT_SECRET=replace_with_long_random_string

# Admin dashboard credentials (ADMIN_PASSWORD_HASH is a bcrypt hash, NOT plaintext)
# Generate hash: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$replace_with_real_bcrypt_hash_here

# JWT token lifetime
JWT_EXPIRES_IN=8h

# ── Service Token (system-to-system pipeline) ──────────────────────────────────
# Shared static secret for Admin→Editor→Public integration routes.
# NOT a user JWT. Must match SERVICE_TOKEN in editor and public .env files.
SERVICE_TOKEN=replace_with_another_long_random_string

# Editor API is served from the Next.js app on port 3002
EDITOR_API_URL=http://localhost:3002
ADMIN_TO_EDITOR_SERVICE_TOKEN=podwave_admin_to_editor_token_2024
