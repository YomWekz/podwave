# PodWave Admin System Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
ADMIN_PORT=4001
ADMIN_CLIENT_URL=http://localhost:3001

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=podwave_admin

# JWT Secret (generate a secure random string)
JWT_SECRET=local_dev_secret_change_later

# Editor System API (for cross-system communication)
# Editor API is served from the Next.js app on port 3002
EDITOR_API_URL=http://localhost:3002
ADMIN_TO_EDITOR_SERVICE_TOKEN=podwave_admin_to_editor_token_2024
