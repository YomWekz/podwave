# PodWave Admin System Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
ADMIN_PORT=4001
ADMIN_CLIENT_URL=http://localhost:3001

# MySQL Database Configuration
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=
MYSQL_DATABASE=podwave_admin

# JWT Secret (generate a secure random string)
JWT_SECRET=local_dev_secret_change_later

# Admin Authentication
# ADMIN_PASSWORD_HASH is a bcrypt hash, not the plaintext password.
# Generate hash: node -e "require('bcryptjs').hash('yourpassword',10).then(console.log)"
ADMIN_JWT_SECRET=replace_with_long_random_string
ADMIN_USERNAME=admin
ADMIN_PASSWORD_HASH=$2b$10$replace_with_real_bcrypt_hash_here
JWT_EXPIRES_IN=8h

# Service token for Admin integration routes
# Send as Authorization: Bearer <SERVICE_TOKEN>
SERVICE_TOKEN=replace_with_another_long_random_string

# Editor System API (for cross-system communication)
# Editor API is served from the Next.js app on port 3002
EDITOR_API_URL=http://localhost:3002
ADMIN_TO_EDITOR_SERVICE_TOKEN=podwave_admin_to_editor_token_2024
