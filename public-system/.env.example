# PodWave Public User System Environment Variables
# Copy this file to .env and fill in your actual values

# Server Configuration
PUBLIC_PORT=4003
PUBLIC_CLIENT_URL=http://localhost:3003

# MongoDB Atlas Connection String
# Get this from your MongoDB Atlas dashboard
# Format: mongodb+srv://<username>:<password>@cluster.mongodb.net/<database>
MONGODB_URI=your_mongodb_atlas_connection_string

# Public User Authentication
PUBLIC_JWT_SECRET=replace_with_secure_public_jwt_secret
PUBLIC_JWT_EXPIRES_IN=30d

# Editor System API Token (for receiving approved podcasts from Editor)
EDITOR_TO_PUBLIC_SERVICE_TOKEN=podwave_editor_to_public_token_2024
