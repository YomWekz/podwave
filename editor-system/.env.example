# PodWave Editor System Environment Variables
# Copy this file to .env and fill in your actual values

# App Configuration
NEXT_PUBLIC_EDITOR_APP_URL=http://localhost:3002

# Supabase Configuration
# Get these from your Supabase project dashboard
SUPABASE_URL=your_supabase_project_url
SUPABASE_ANON_KEY=your_supabase_anon_key

# WARNING: Never expose the service role key in frontend code!
# This key is for server-side API routes only
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_server_only

# JWT Secret (generate a secure random string)
JWT_SECRET=replace_with_secure_secret

# Admin System API Token (for receiving data from Admin)
# Must match ADMIN_TO_EDITOR_SERVICE_TOKEN in Admin .env
ADMIN_TO_EDITOR_SERVICE_TOKEN=podwave_admin_to_editor_token_2024

# Public System API (for sending approved podcasts to Public)
PUBLIC_API_URL=http://localhost:4003
EDITOR_TO_PUBLIC_SERVICE_TOKEN=podwave_editor_to_public_token_2024
